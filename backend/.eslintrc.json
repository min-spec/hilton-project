{
  "env": {
    "node": true,
    "commonjs": true,
    "es2021": true,
    "jest": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:node/recommended",
    "plugin:jest/recommended",
    "plugin:prettier/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "node/no-unsupported-features/es-syntax": ["error", {
      "version": ">=14.0.0",
      "ignores": ["modules"]
    }],
    "node/no-unpublished-require": ["error", {
      "allowModules": ["mongodb-memory-server", "supertest"]
    }],
    "no-process-exit": "off"
  }
}
